# DroneDream environment template.
# Copy to .env and edit for local development. Do not commit real secrets.

# --- Backend (FastAPI) ---
# Host/port the API listens on.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Application environment: development | test | production
APP_ENV=development

# CORS: comma-separated origins allowed by the API.
CORS_ORIGINS=http://localhost:5173

# Database URL. SQLite for local MVP; swap for Postgres later.
DATABASE_URL=sqlite:///./drone_dream.db

# Log level: debug | info | warning | error
LOG_LEVEL=info

# --- Worker ---
# How often the worker polls the DB queue for trial work, in seconds.
WORKER_POLL_INTERVAL_SECONDS=1.0

# Worker log level (defaults to LOG_LEVEL if unset).
WORKER_LOG_LEVEL=info

# Simulator backend selection (global override).
# Supported: mock | real_stub | real_cli
# - mock: deterministic in-process simulator used by the MVP (Phase 4).
# - real_stub: placeholder that always returns ADAPTER_UNAVAILABLE (Phase 4).
# - real_cli: subprocess adapter that invokes REAL_SIMULATOR_COMMAND with a
#   JSON file protocol (Phase 8). See docs/PHASE8_REAL_SIM_AND_GPT_TUNING.md.
#
# IMPORTANT — leave this UNSET (blank) for normal use. When blank, each job
# uses its own ``simulator_backend`` field (selected in the New Job UI).
# Setting a value here OVERRIDES every job's selection globally and is only
# intended for back-compat with Phase 7 deployments or for forcing all jobs
# through a specific backend during debugging.
#
# Examples (uncomment at most one):
# SIMULATOR_BACKEND=mock
# SIMULATOR_BACKEND=real_cli
# SIMULATOR_BACKEND=real_stub
SIMULATOR_BACKEND=

# --- Phase 8: real_cli simulator adapter ---
# Full command line to invoke the external simulator. May contain
# ``{input}`` / ``{output}`` placeholders; otherwise ``--input <path>
# --output <path>`` is appended automatically.
REAL_SIMULATOR_COMMAND=
# Working directory for the subprocess (defaults to the trial run dir).
REAL_SIMULATOR_WORKDIR=
# Hard wall-clock timeout per trial invocation, in seconds.
REAL_SIMULATOR_TIMEOUT_SECONDS=300
# Root directory under which per-job/per-trial run dirs are created.
REAL_SIMULATOR_ARTIFACT_ROOT=./.artifacts
# When true, run dirs are retained after the trial finishes (for debugging).
REAL_SIMULATOR_KEEP_RUN_DIRS=true

# --- Phase 8: PX4/Gazebo external runner (used by real_cli) ---
# Configure REAL_SIMULATOR_COMMAND to point at:
#   python3 /abs/path/scripts/simulators/px4_gazebo_runner.py
#
# The runner can execute a real site-specific launcher command OR run in
# deterministic dry-run mode for CI/dev machines without PX4/Gazebo.
PX4_GAZEBO_LAUNCH_COMMAND=
PX4_GAZEBO_WORKDIR=
PX4_GAZEBO_TIMEOUT_SECONDS=300
PX4_GAZEBO_HEADLESS=true
PX4_GAZEBO_KEEP_RAW_LOGS=true
PX4_GAZEBO_DRY_RUN=false
PX4_GAZEBO_PASS_RMSE=0.75
PX4_GAZEBO_PASS_MAX_ERROR=2.0
PX4_GAZEBO_MIN_TRACK_COVERAGE=0.9
PX4_GAZEBO_VEHICLE=
PX4_GAZEBO_WORLD=
PX4_GAZEBO_EXTRA_ARGS=
PX4_GAZEBO_TELEMETRY_FORMAT=json
PX4_GAZEBO_ALLOW_CSV_TELEMETRY=false

# --- Phase 8: GPT parameter proposer ---
# Fernet key used to encrypt per-job OpenAI API keys at rest. REQUIRED if any
# job uses ``optimizer_strategy=gpt``. Must be visible to BOTH the backend
# process (so job creation can encrypt the key) AND the worker process (so it
# can decrypt and call OpenAI). Recommended local setup: put it in this
# root-level .env (sourced by both dev scripts), or export it in both terminals.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=
# Default OpenAI model to use when a job does not specify one.
OPENAI_MODEL=gpt-4.1

# --- Frontend (Vite) ---
# Base URL the frontend uses to reach the backend.
VITE_API_BASE_URL=http://127.0.0.1:8000
